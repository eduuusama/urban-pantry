<section class="py-20 px-6 grain-overlay">
  <div class="max-w-7xl mx-auto">

    {%- comment -%} Section Heading {%- endcomment -%}
    <div class="text-center mb-12">
      <h2 class="font-display text-6xl lg:text-7xl text-foreground">The Collection</h2>
    </div>

    {%- comment -%} Products Grid {%- endcomment -%}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      {%- for product in collections['sauces'].products limit: 4 -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>

    {%- comment -%} View All Link {%- endcomment -%}
    <div class="text-center">
      <a
        href="/collections/all"
        class="text-primary border-b-2 border-primary hover:opacity-75 transition-opacity font-body text-sm tracking-wide"
      >
        View All Products →
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": []
}
{% endschema %}
