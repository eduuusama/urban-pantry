{%- comment -%}
  Not Found (404) Section
  Error page with grain overlay and CTA back to shop
{%- endcomment -%}

<section class="grain-overlay" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem;">
  <div data-reveal style="text-align: center; max-width: 600px; margin: 0 auto;">

    <h1 class="font-display text-foreground" style="font-size: clamp(2.5rem, 10vw, 3.75rem); line-height: 1.2; margin-bottom: 1rem;">
      Sauce Not Found
    </h1>

    <p class="text-muted-foreground" style="font-family: var(--font-body); font-size: 1.125rem; font-weight: 300; margin-bottom: 3rem;">
      This bottle must've rolled off the shelf.
    </p>

    <a href="/collections/all" style="display: inline-block; background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); padding: 1rem 2rem; text-decoration: none; font-family: var(--font-display); font-size: 1.125rem; letter-spacing: 0.1em; text-transform: uppercase; transition: opacity 0.2s ease;">
      Back to Shop
    </a>

  </div>
</section>

{% schema %}
{
  "name": "Not Found"
}
{% endschema %}
