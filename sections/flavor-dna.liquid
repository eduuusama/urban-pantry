<section class="bg-secondary grain-overlay" style="padding: 6rem 1rem;">
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Heading -->
    <h2 class="font-display text-foreground text-center" style="font-size: 3.5rem; margin: 0 0 2rem 0; line-height: 1.1;">Flavor DNA</h2>
    <div class="section-divider" style="margin-bottom: 3rem;"></div>

    <!-- Content Grid -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;">

      <!-- LEFT: Flavor Bars -->
      <div>
        {% assign flavor_heat = product.metafields.custom.flavor_heat.value | plus: 0 %}
        {% assign flavor_smokiness = product.metafields.custom.flavor_smokiness.value | plus: 0 %}
        {% assign flavor_acidity = product.metafields.custom.flavor_acidity.value | plus: 0 %}
        {% assign flavor_complexity = product.metafields.custom.flavor_complexity.value | plus: 0 %}
        {% assign accent_color = product.metafields.custom.accent_color.value %}

        <!-- Heat Bar -->
        <div data-flavor-bar data-value="{{ flavor_heat }}" data-color="{{ accent_color }}" data-delay="0ms" style="margin-bottom: 2.5rem;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 0.375rem;">
            <span class="font-display" style="font-size: 0.75rem; letter-spacing: 0.2em; color: hsl(var(--foreground)); text-transform: uppercase;">Heat</span>
            <span class="font-display" style="font-size: 0.75rem; color: hsl(var(--muted-foreground));">{{ flavor_heat }}/5</span>
          </div>
          <div style="height: 0.75rem; background: hsla(var(--border), 0.4); border-radius: 9999px; overflow: hidden;">
            <div class="flavor-bar-fill" style="background-color: {{ accent_color }}; height: 100%; width: 0%; transition: width 0.8s ease-out; transition-delay: 0ms;"></div>
          </div>
        </div>

        <!-- Smokiness Bar -->
        <div data-flavor-bar data-value="{{ flavor_smokiness }}" data-color="{{ accent_color }}" data-delay="100ms" style="margin-bottom: 2.5rem;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 0.375rem;">
            <span class="font-display" style="font-size: 0.75rem; letter-spacing: 0.2em; color: hsl(var(--foreground)); text-transform: uppercase;">Smokiness</span>
            <span class="font-display" style="font-size: 0.75rem; color: hsl(var(--muted-foreground));">{{ flavor_smokiness }}/5</span>
          </div>
          <div style="height: 0.75rem; background: hsla(var(--border), 0.4); border-radius: 9999px; overflow: hidden;">
            <div class="flavor-bar-fill" style="background-color: {{ accent_color }}; height: 100%; width: 0%; transition: width 0.8s ease-out; transition-delay: 100ms;"></div>
          </div>
        </div>

        <!-- Acidity Bar -->
        <div data-flavor-bar data-value="{{ flavor_acidity }}" data-color="{{ accent_color }}" data-delay="200ms" style="margin-bottom: 2.5rem;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 0.375rem;">
            <span class="font-display" style="font-size: 0.75rem; letter-spacing: 0.2em; color: hsl(var(--foreground)); text-transform: uppercase;">Acidity</span>
            <span class="font-display" style="font-size: 0.75rem; color: hsl(var(--muted-foreground));">{{ flavor_acidity }}/5</span>
          </div>
          <div style="height: 0.75rem; background: hsla(var(--border), 0.4); border-radius: 9999px; overflow: hidden;">
            <div class="flavor-bar-fill" style="background-color: {{ accent_color }}; height: 100%; width: 0%; transition: width 0.8s ease-out; transition-delay: 200ms;"></div>
          </div>
        </div>

        <!-- Complexity Bar -->
        <div data-flavor-bar data-value="{{ flavor_complexity }}" data-color="{{ accent_color }}" data-delay="300ms">
          <div style="display: flex; justify-content: space-between; margin-bottom: 0.375rem;">
            <span class="font-display" style="font-size: 0.75rem; letter-spacing: 0.2em; color: hsl(var(--foreground)); text-transform: uppercase;">Complexity</span>
            <span class="font-display" style="font-size: 0.75rem; color: hsl(var(--muted-foreground));">{{ flavor_complexity }}/5</span>
          </div>
          <div style="height: 0.75rem; background: hsla(var(--border), 0.4); border-radius: 9999px; overflow: hidden;">
            <div class="flavor-bar-fill" style="background-color: {{ accent_color }}; height: 100%; width: 0%; transition: width 0.8s ease-out; transition-delay: 300ms;"></div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Origin & Quote -->
      <div>
        <!-- Origin Region -->
        {% if product.metafields.custom.origin_region.value %}
          <div style="margin-bottom: 2.5rem;">
            <p class="font-display" style="font-size: 0.75rem; letter-spacing: 0.2em; color: hsl(var(--muted-foreground)); text-transform: uppercase; margin: 0 0 0.5rem 0;">Origin Region</p>
            <p class="font-body text-foreground" style="margin: 0; font-size: 1.125rem;">{{ product.metafields.custom.origin_region.value }}</p>
          </div>
        {% endif %}

        <!-- Origin Ingredients -->
        {% if product.metafields.custom.origin_ingredients.value %}
          <div style="margin-bottom: 2.5rem;">
            <p class="font-display" style="font-size: 0.75rem; letter-spacing: 0.2em; color: hsl(var(--muted-foreground)); text-transform: uppercase; margin: 0 0 0.75rem 0;">Origin Ingredients</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
              {% for ingredient in product.metafields.custom.origin_ingredients.value %}
                <span class="font-body" style="font-size: 0.875rem; color: hsl(var(--foreground));">{{ ingredient }}</span>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <!-- Chef Quote -->
        {% if product.metafields.custom.chef_quote.value %}
          <blockquote class="spray-quote" style="padding-left: 1rem; margin-top: 2rem; border-left: 3px solid {{ accent_color }};">
            <p class="font-raw" style="font-size: 1.5rem; color: {{ accent_color }}; transform: rotate(-0.5deg); margin: 0;">
              "{{ product.metafields.custom.chef_quote.value }}"
            </p>
            <footer class="font-display" style="font-size: 0.875rem; letter-spacing: 0.15em; color: hsl(var(--primary)); margin-top: 1rem;">
              — Chef Arik Markus
            </footer>
          </blockquote>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const flavorBars = document.querySelectorAll('[data-flavor-bar]');

  const observerOptions = {
    threshold: 0.5,
    rootMargin: '0px'
  };

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bar = entry.target;
        const value = parseInt(bar.getAttribute('data-value'));
        const delay = parseInt(bar.getAttribute('data-delay'));
        const fill = bar.querySelector('.flavor-bar-fill');
        const percentage = (value / 5) * 100;

        setTimeout(() => {
          fill.style.width = percentage + '%';
        }, delay);

        observer.unobserve(bar);
      }
    });
  }, observerOptions);

  flavorBars.forEach(bar => observer.observe(bar));
});
</script>

{% schema %}
{
  "name": "Flavor DNA",
  "settings": []
}
{% endschema %}
