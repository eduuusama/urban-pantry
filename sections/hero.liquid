<!-- Desktop Hero -->
<section
  id="hero-desktop"
  class="grain-overlay grain-heavy"
  style="position: relative; min-height: 100vh; overflow: hidden; display: none;"
  aria-label="Hero section"
>
  <!-- Background image -->
  <div style="position: absolute; inset: 0;">
    <img
      src="{{ 'hero-desktop.webp' | asset_url }}"
      alt="Urban Pantry hot sauce collection"
      style="width: 100%; height: 100%; object-fit: cover; object-position: right center;"
      width="1330"
      height="800"
    />
    <div style="position: absolute; inset: 0; background: linear-gradient(to right, hsl(var(--background)) 0%, hsl(var(--background) / 0.8) 35%, transparent 100%);"></div>
  </div>

  <!-- Content -->
  <div style="position: relative; z-index: 2; max-width: 80rem; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; min-height: 100vh;">
    <div style="max-width: 36rem;">
      <h1
        class="font-display animate-word-reveal"
        style="font-size: clamp(3rem, 5vw, 4.5rem); line-height: 0.95; color: hsl(var(--foreground)); margin-bottom: 0.5rem; animation-delay: 300ms;"
      >Chef-Crafted Heat.</h1>

      <h2
        class="font-raw animate-word-reveal"
        style="font-size: clamp(2.5rem, 4vw, 3.75rem); color: hsl(var(--primary)); transform: rotate(-1deg); display: inline-block; margin-bottom: 1.5rem; animation-delay: 450ms;"
      >Street-Born Flavor.</h2>

      <p
        class="font-body"
        style="font-size: 1.125rem; color: hsl(var(--muted-foreground)); max-width: 32rem; line-height: 1.6; margin-bottom: 2.5rem; font-weight: 300; opacity: 0; animation: page-enter 0.6s ease forwards; animation-delay: 600ms;"
      >Real peppers. Real spices. Real flavor — sourced from where they're born, crafted by a Michelin-trained chef.</p>

      <div style="opacity: 0; animation: page-enter 0.6s ease forwards; animation-delay: 750ms;">
        <a
          href="/collections/all"
          class="font-display animate-cta-pulse"
          style="display: inline-block; background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); font-size: 1.125rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 1rem 2.5rem; text-decoration: none; transition: opacity 0.2s;"
        >Shop the Collection</a>
      </div>
    </div>
  </div>
</section>

<!-- Mobile Hero -->
<section
  id="hero-mobile"
  class="grain-overlay"
  style="background: hsl(var(--background)); overflow: hidden;"
  aria-label="Hero section"
>
  <div style="padding: 3rem 1rem 2rem; text-align: center;">
    <h1
      class="font-display animate-word-reveal"
      style="font-size: 2.75rem; line-height: 0.95; color: hsl(var(--foreground)); margin-bottom: 0.5rem; animation-delay: 300ms;"
    >Chef-Crafted Heat.</h1>

    <h2
      class="font-raw animate-word-reveal"
      style="font-size: 2.25rem; color: hsl(var(--primary)); transform: rotate(-1deg); display: inline-block; margin-bottom: 1rem; animation-delay: 450ms;"
    >Street-Born Flavor.</h2>

    <p
      class="font-body"
      style="font-size: 0.875rem; color: hsl(var(--muted-foreground)); max-width: 20rem; margin: 0 auto 1.5rem; line-height: 1.6; font-weight: 300; opacity: 0; animation: page-enter 0.6s ease forwards; animation-delay: 600ms;"
    >Real peppers. Real spices. Real flavor — sourced from where they're born, crafted by a Michelin-trained chef.</p>

    <div style="opacity: 0; animation: page-enter 0.6s ease forwards; animation-delay: 750ms;">
      <a
        href="/collections/all"
        class="font-display"
        style="display: inline-block; background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); font-size: 0.875rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.625rem 1.25rem; text-decoration: none;"
      >Shop the Collection</a>
    </div>
  </div>

  <div style="padding: 0 1rem 1rem;">
    <img
      src="{{ 'hero-mobile.webp' | asset_url }}"
      alt="Urban Pantry hot sauce collection"
      style="width: 100%; max-width: 28rem; margin: 0 auto; display: block; object-fit: contain;"
      width="665"
      height="665"
    />
  </div>
</section>

<style>
  /* Desktop: show desktop hero, hide mobile hero */
  @media (min-width: 768px) {
    #hero-desktop { display: block !important; }
    #hero-mobile  { display: none !important; }
  }
  /* Mobile: show mobile hero (it's visible by default since desktop is display:none) */
  @media (max-width: 767px) {
    #hero-desktop { display: none !important; }
    #hero-mobile  { display: block !important; }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": []
}
{% endschema %}
