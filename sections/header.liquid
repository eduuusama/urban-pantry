<header class="site-header" id="site-header" style="position: sticky; top: 0; z-index: 40; background: hsl(var(--background));">

  <!-- Announcement Bar -->
  <div style="background: hsl(var(--primary)); overflow: hidden; padding: 0.375rem 0;" aria-hidden="true">
    <div class="animate-marquee-fast whitespace-nowrap flex distressed-text">
      {%- for i in (1..2) -%}
        <span class="font-display tracking-widest text-primary-foreground" style="font-size: 0.875rem; letter-spacing: 0.15em; padding-right: 2rem; flex-shrink: 0; display: inline-block;">
          FREE SHIPPING on orders over $30 &nbsp;&nbsp;·&nbsp;&nbsp; FREE SHIPPING on orders over $30 &nbsp;&nbsp;·&nbsp;&nbsp; FREE SHIPPING on orders over $30 &nbsp;&nbsp;·&nbsp;&nbsp; FREE SHIPPING on orders over $30 &nbsp;&nbsp;·&nbsp;&nbsp;
        </span>
      {%- endfor -%}
    </div>
  </div>

  <!-- Main Navigation -->
  <nav style="background: hsl(var(--background) / 0.95); backdrop-filter: blur(8px); border-bottom: 1px solid hsl(var(--border));" aria-label="Main navigation">
    <div class="max-w-7xl mx-auto px-6" style="display: flex; align-items: center; justify-content: space-between; height: 4rem; transition: height 0.3s ease;" id="nav-inner">

      <!-- Logo -->
      <a href="/" style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; text-decoration: none;" aria-label="Urban Pantry Home">
        <img
          src="{{ 'logo.png' | asset_url }}"
          alt=""
          id="nav-logo"
          style="height: 2rem; width: auto; transition: height 0.3s ease; flex-shrink: 0;"
        />
        <span class="font-raw" style="font-size: 1.375rem; color: hsl(var(--foreground)); line-height: 1; letter-spacing: 0.02em;" id="nav-brand-name">Urban Pantry</span>
      </a>

      <!-- Desktop Nav Links -->
      <ul style="display: none; align-items: center; gap: 2rem; list-style: none; margin: 0; padding: 0;" id="desktop-nav">
        {%- assign nav_labels = "Home,Shop,Saucy Story,Find Us,Contact" | split: "," -%}
        {%- assign nav_hrefs = "/,/collections/all,/pages/saucy-story,/pages/find-us,/pages/contact" | split: "," -%}
        {%- for i in (0..4) -%}
          <li>
            <a
              href="{{ nav_hrefs[i] }}"
              class="font-display"
              style="font-size: 0.875rem; letter-spacing: 0.15em; text-transform: uppercase; color: {% if request.path == nav_hrefs[i] %}hsl(var(--primary)){% else %}hsl(var(--muted-foreground)){% endif %}; text-decoration: none; transition: color 0.2s;"
            >{{ nav_labels[i] }}</a>
          </li>
        {%- endfor -%}
      </ul>

      <!-- Cart + Hamburger -->
      <div style="display: flex; align-items: center; gap: 1rem;">
        <!-- Cart trigger -->
        <button
          data-cart-toggle
          style="position: relative; background: none; border: none; cursor: pointer; color: hsl(var(--foreground)); padding: 0.5rem;"
          aria-label="Open cart"
        >
          <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          <span
            data-cart-count
            style="display: {% if cart.item_count > 0 %}flex{% else %}none{% endif %}; position: absolute; top: 0; right: 0; background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); font-family: var(--font-display); font-size: 0.625rem; font-weight: 700; width: 1.125rem; height: 1.125rem; border-radius: 9999px; align-items: center; justify-content: center;"
          >{{ cart.item_count }}</span>
        </button>

        <!-- Hamburger (mobile) -->
        <button
          data-menu-open
          style="background: none; border: none; cursor: pointer; color: hsl(var(--foreground)); padding: 0.5rem;"
          id="hamburger-btn"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Nav Overlay -->
  <div class="mobile-nav-overlay" id="mobile-nav-overlay" role="dialog" aria-modal="true" aria-label="Mobile navigation">
    <button
      data-menu-close
      style="position: absolute; top: 1.5rem; right: 1.5rem; background: none; border: none; cursor: pointer; color: hsl(var(--foreground)); padding: 0.5rem;"
      aria-label="Close menu"
    >
      <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <nav>
      {%- for i in (0..4) -%}
        <a
          href="{{ nav_hrefs[i] }}"
          class="font-display animate-slide-in-link"
          style="font-size: 2.5rem; letter-spacing: 0.2em; text-transform: uppercase; color: hsl(var(--foreground)); display: block; margin-bottom: 2rem; text-decoration: none; animation-delay: {{ i | times: 80 | plus: 100 }}ms;"
        >{{ nav_labels[i] }}</a>
      {%- endfor -%}
    </nav>
  </div>

</header>

<style>
  #desktop-nav { display: none; }
  @media (min-width: 768px) {
    #desktop-nav { display: flex !important; }
    #hamburger-btn { display: none !important; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
