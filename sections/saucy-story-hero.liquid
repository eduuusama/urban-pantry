<section class="bg-secondary grain-heavy" style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 4rem 1rem;">
  <div data-reveal style="text-align: center; max-width: 900px; margin: 0 auto;">

    {%- comment -%}Label{%- endcomment -%}
    <p class="font-raw text-primary" style="font-size: 1.25rem; transform: rotate(-1deg); margin-bottom: 1rem;">
      The Saucy Story
    </p>

    {%- comment -%}Main heading with word-reveal animation{%- endcomment -%}
    <h1 class="font-display text-foreground" style="font-size: clamp(2.5rem, 10vw, 8rem); line-height: 1.1; margin-bottom: 2rem; word-break: break-word;" data-word-reveal>
      Heat Born from the Streets.
    </h1>

    {%- comment -%}Subtext{%- endcomment -%}
    <p class="text-muted-foreground" style="font-family: var(--font-body); font-size: 1.125rem; font-weight: 300; max-width: 600px; margin: 0 auto;">
      Every sauce has a story. This is ours.
    </p>

  </div>
</section>

{% schema %}
{
  "name": "Saucy Story Hero"
}
{% endschema %}
