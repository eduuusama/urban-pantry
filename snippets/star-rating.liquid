{% comment %}
  Renders a 5-star rating

  Parameters:
  - stars (integer 1-5): number of filled stars
  - accent_color (string): hex color for filled stars
{% endcomment %}

<div style="display: flex; gap: 0.25rem;">
  {% for i in (1..5) %}
    {% if i <= stars %}
      <!-- Filled Star -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="{{ accent_color }}" style="flex-shrink: 0;">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {% else %}
      <!-- Empty Star -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="hsl(var(--border))" stroke-width="2" style="flex-shrink: 0;">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {% endif %}
  {% endfor %}
</div>
