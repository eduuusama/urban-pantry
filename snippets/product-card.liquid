{% comment %}
  Renders a product card for collections and cross-sell sections

  Parameters:
  - product (Shopify product object)
{% endcomment %}

{% assign accent_color = product.metafields.custom.accent_color.value %}
{% unless accent_color %}
  {% case product.handle %}
    {% when 'bomba-sauce' %}{% assign card_bg = '#fef3cd' %}{% assign accent_color = '#D79523' %}
    {% when 'mo-rockin-sauce' %}{% assign card_bg = '#f5ede0' %}{% assign accent_color = '#C8A800' %}
    {% when 'piquin-hot' %}{% assign card_bg = '#fde8d8' %}{% assign accent_color = '#FA711B' %}
    {% when 'sambal-istic-sauce' %}{% assign card_bg = '#fde0e0' %}{% assign accent_color = '#D24843' %}
    {% else %}{% assign card_bg = 'hsl(var(--secondary))' %}{% assign accent_color = 'hsl(var(--primary))' %}
  {% endcase %}
{% else %}
  {% assign card_bg = 'hsl(var(--secondary))' %}
{% endunless %}

<div style="border-radius: 0.5rem; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.08);" onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 16px 40px rgba(0,0,0,0.14)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)';">

  <!-- Image -->
  <a href="{{ product.url }}" style="display: flex; align-items: center; justify-content: center; aspect-ratio: 1; overflow: hidden; background-color: {{ card_bg }}; position: relative;">
    <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}" style="width: 70%; height: 90%; object-fit: contain; filter: drop-shadow(0 12px 24px rgba(0,0,0,0.18)); transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">

    {% if product.metafields.custom.badge.value %}
      <span style="position: absolute; top: 1rem; right: 1rem; font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.5rem 0.75rem; color: white; background-color: {{ accent_color }};">
        {{ product.metafields.custom.badge.value }}
      </span>
    {% endif %}
  </a>

  <!-- Details -->
  <div style="padding: 1.5rem;">

    <!-- Subtitle -->
    {% if product.metafields.custom.subtitle.value %}
      <p class="font-raw" style="font-size: 0.875rem; color: {{ accent_color }}; margin: 0 0 0.5rem 0; transform: rotate(-1deg);">
        {{ product.metafields.custom.subtitle.value }}
      </p>
    {% endif %}

    <!-- Title -->
    <a href="{{ product.url }}" style="text-decoration: none;">
      <h3 class="font-display text-foreground" style="font-size: 1.25rem; margin: 0 0 0.75rem 0; line-height: 1.2;">
        {{ product.title }}
      </h3>
    </a>

    <!-- Price -->
    <p class="font-display text-primary" style="font-size: 1.25rem; margin: 0.75rem 0;">
      {{ product.price | money }}
    </p>

    <!-- Add to Cart -->
    <button class="btn-add-to-cart font-display" data-variant-id="{{ product.selected_or_first_available_variant.id }}" style="font-size: 0.875rem; letter-spacing: 0.15em; text-transform: uppercase; background-color: hsl(var(--primary)); color: hsl(var(--primary-foreground)); padding: 0.75rem 1.5rem; width: 100%; border: none; border-radius: 0.375rem; cursor: pointer; margin-top: 1rem; font-weight: 600; transition: all 0.3s ease;" onmouseover="this.style.opacity = '0.9';" onmouseout="this.style.opacity = '1';">
      Add to Cart
    </button>

  </div>

</div>
