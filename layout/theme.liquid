<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#c0392b">

  <title>{{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  {% if page_image %}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
  {% endif %}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Permanent+Marker&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  <!-- Organization JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Urban Pantry",
    "url": "{{ shop.url }}",
    "logo": "{{ 'logo.png' | asset_url }}",
    "sameAs": [
      "https://www.instagram.com/eaturbanpantry",
      "https://www.facebook.com/eaturbanpantry"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "info@eaturbanpantry.com",
      "contactType": "customer service"
    }
  }
  </script>
</head>

<body>
  <a class="skip-to-content" href="#main-content">Skip to content</a>

  {% section 'promo-popup' %}

  <div class="cart-overlay" id="cart-overlay"></div>

  {% section 'header' %}

  {% render 'cart-drawer' %}

  <main id="main-content" role="main" class="page-enter">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Theme JS -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
